{
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/comece-a-orquestrar", "destination": "/2026/talk-comece-a-orquestrar/index.html" },
    { "source": "/comece-a-orquestrar/assets/:path*", "destination": "/2026/talk-comece-a-orquestrar/assets/:path*" },
    { "source": "/team-topologies", "destination": "/2026/team-topologies/index.html" },
    { "source": "/team-topologies/:path*", "destination": "/2026/team-topologies/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
